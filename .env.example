# Database: Use sqlite for local dev, or mysql database
# Example MySQL: DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/proctor_db
DATABASE_URL=sqlite:///./proctoring.db

# Authentication Security
JWT_SECRET=your-256-bit-secret-key-here

# YOLO v8 Model selection (yolov8n.pt, yolov8s.pt, yolov8m.pt)
YOLO_MODEL=yolov8s.pt

# Evidence folder path
EVIDENCE_DIR=evidence

# Initial Seed Admin Account
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123
